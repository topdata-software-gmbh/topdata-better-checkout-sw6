{% sw_extends '@Storefront/storefront/page/account/addressbook/address-manager.html.twig' %}

{% block address_base_default_address_item %}
    {% sw_include '@Storefront/storefront/page/account/addressbook/address-item.html.twig' with {
        address: defaultBillingAddress,
        defaultBilling: true,
        defaultShipping: defaultShippingAddress.id == defaultBillingAddress.id,
        isBillingAddress: true
    }  %}
{% endblock %}

{% block address_base_list_title %}
    <h2 class="mt-4">
        {{ "better-checkout.account.addressesAvailable"|trans|sw_sanitize }}
    </h2>
    <p>
        {{ "account.addressText"|trans|sw_sanitize }}
    </p>
{% endblock %}

{% block address_base_list_address_item %}
    {% if address.id != defaultBillingAddress.id %}
        {% sw_include '@Storefront/storefront/page/account/addressbook/address-item.html.twig' with {
            address: address,
            defaultShipping: defaultShippingAddress.id == address.id,
            defaultBilling: false
        }  %}
    {% endif %}
{% endblock %}

{% block address_base_list %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var searchContainer = document.querySelector('[data-address-search]');
            if (!searchContainer) return;

            var searchInput = searchContainer.querySelector('.address-manager-list-search');
            var searchContent = searchContainer.querySelector('.address-manager-list-wrapper');
            var notFound = searchContainer.querySelector('.address-manager-no-address');
            var empty = searchContainer.querySelector('.address-manager-empty-address');
            if (!searchInput || !searchContent) return;

            function filterAddresses() {
                var query = searchInput.value.toLowerCase();
                var items = searchContent.children;
                var visibleCount = 0;

                Array.from(items).forEach(function(item) {
                    var searchItem = item.querySelector('.address-manager-select-address');
                    if (!searchItem) return;

                    var text = searchItem.textContent.toLowerCase();
                    if (text.includes(query)) {
                        item.style.removeProperty('display');
                        item.classList.remove('d-none');
                        visibleCount++;
                    } else {
                        item.style.setProperty('display', 'none', 'important');
                        item.classList.add('d-none');
                    }
                });

                if (notFound) notFound.classList.add('d-none');
                if (empty) empty.classList.add('d-none');

                if (visibleCount === 0) {
                    if (query.length === 0) {
                        if (empty) empty.classList.remove('d-none');
                    } else {
                        if (notFound) notFound.classList.remove('d-none');
                    }
                }
            }

            searchInput.addEventListener('input', filterAddresses);
        });
    </script>
{% endblock %}
